# LLM Provider: anthropic | openai | ollama
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_BASE_URL=https://your-proxy.example.com  # 可选，自定义 API 地址
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001           # 可选，自定义模型名

# OpenAI (及兼容 OpenAI 协议的服务：DeepSeek、vLLM、LM Studio 等)
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://your-proxy.example.com/v1  # 可选，自定义端点
# OPENAI_MODEL=gpt-4o-mini                            # 可选，自定义模型名

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Simulation
PORT=3001
TICK_INTERVAL_MS=1000
SIM_MINUTES_PER_TICK=5
MAX_AGENTS=25

# Database
DB_PATH=./data/town.db
